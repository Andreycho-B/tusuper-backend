# .env.test.example
# Plantilla para entorno de testing. Copia este archivo a .env.test y rellena
# los valores. NUNCA commitees el .env.test real.
#
# Para generar un JWT_SECRET fuerte:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

PORT=3000

# Base de datos de testing (idealmente distinta de la de desarrollo)
POSTGRES_DB=tusuper_test
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# JWT — debe ser un valor aleatorio de al menos 32 caracteres.
# El esquema Joi en app.module.ts rechaza secrets < 32 chars.
JWT_SECRET=replace_with_random_value_64_bytes_hex_minimum_32_chars
JWT_EXPIRES_IN=900

# Mail (credenciales de testing — usa una cuenta dedicada, nunca la de producción)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=replace_me
MAIL_PASSWORD=replace_me
MAIL_FROM="TuSuper Test <test@example.com>"

# Google OAuth (credenciales de testing)
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

FRONTEND_URL=http://localhost:4200
