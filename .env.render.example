# Variables para Render (configúralas en el dashboard o con render.yaml)
# No subas este archivo con valores reales al repositorio.

NODE_ENV=production
SKIP_ENV_FILE=true
RENDER=true

# Render Postgres inyecta DATABASE_URL automáticamente.
# DATABASE_URL=postgresql://user:pass@host:5432/tusuper

JWT_SECRET=genera_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=86400

# URL pública del frontend en Render (Static Site)
FRONTEND_URL=https://tusuper-frontend.onrender.com

# Google OAuth — callback debe apuntar al API en Render
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://tusuper-api.onrender.com/auth/google/callback

# Correo (Gmail con contraseña de aplicación u otro SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="TuSuper <no-reply@tusuper.com>"

# Cloudinary (imágenes de productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed de producción (mínimo 16 caracteres)
SEED_SECRET=genera_otro_secreto_largo

# Usuario administrador inicial
ADMIN_EMAIL=admin@tusuper.com
ADMIN_PASSWORD=CambiaEstaClave123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=TuSuper
