# .env.example
# Copia este archivo a .env y completa los valores. NUNCA commitees el .env real.
#
# Para generar un JWT_SECRET fuerte (recomendado 64 bytes hex = 128 chars):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# El esquema Joi en src/app.module.ts rechaza secrets de menos de 32 caracteres.

PORT=3000

# Base de datos
POSTGRES_DB=nombre_base_datos
POSTGRES_USER=usuario_local
POSTGRES_PASSWORD=tu_password_local
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# JWT — DEBE ser un valor aleatorio fuerte (>= 32 chars). Rotar periódicamente
# y de inmediato si se sospecha compromiso. Rotar invalida todas las sesiones.
JWT_SECRET=reemplazar_con_un_secreto_aleatorio_de_64_bytes_hex
JWT_EXPIRES_IN=3600

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=tu_usuario_smtp
MAIL_PASSWORD=tu_password_smtp
MAIL_FROM="TuSuper <no-reply@example.com>"

# Google OAuth
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:4200