# .env.render.example — Variables para desplegar en Render
# Completa estos valores y agregalos en el dashboard de Render.
# NUNCA commitees los valores reales.

# ── Base de datos (Clever Cloud) ──
# Pega aqui la URL de conexion de Clever Cloud
DATABASE_URL=postgres://user:password@host:port/dbname

# ── JWT ──
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generar_secreto_aleatorio_min_32_caracteres
JWT_EXPIRES_IN=86400

# ── Mail (SMTP) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_FROM="TuSuper <tu_correo@gmail.com>"

# ── Google OAuth ──
GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_CALLBACK_URL=https://TU-API.onrender.com/auth/google/callback

# ── Frontend (URL del Static Site en Render) ──
FRONTEND_URL=https://TU-FRONTEND.onrender.com

# ── Cloudinary (subida de imagenes) ──
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Seed de produccion ──
SEED_SECRET=secreto_largo_para_proteger_el_seed
ADMIN_EMAIL=admin@tusuper.com
ADMIN_PASSWORD=admin_password_inicial
