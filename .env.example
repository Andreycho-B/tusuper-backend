# .env.example — copia a .env para desarrollo local
PORT=3000
NODE_ENV=dev

POSTGRES_DB=auth_db
POSTGRES_USER=root
POSTGRES_PASSWORD=tu_password_local
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# En Render se usa DATABASE_URL (ver .env.render.example)
# DATABASE_URL=postgresql://user:pass@host:5432/db

JWT_SECRET=reemplazar_con_secreto_local
JWT_EXPIRES_IN=3600
FRONTEND_URL=http://localhost:4200

# Google OAuth
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Cloudinary (imágenes de productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed de producción (POST /seed/production con header x-seed-secret)
SEED_SECRET=secreto_largo_solo_para_seed
ADMIN_EMAIL=admin@tusuper.com
ADMIN_PASSWORD=CambiaEstaClave123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=TuSuper