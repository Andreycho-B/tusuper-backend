# .env.example — Backend TuSuper
# Copia este archivo a .env y completa los valores.
# NUNCA commitees el .env real.

PORT=3000

# ── Base de datos local ──
POSTGRES_DB=auth_db
POSTGRES_USER=root
POSTGRES_PASSWORD=cambiar_por_password_seguro
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# ── Base de datos en la nube (Clever Cloud, Render, etc.) ──
# Si defines DATABASE_URL, los POSTGRES_* de arriba se ignoran.
# DATABASE_URL=postgres://user:password@host:port/dbname

# ── JWT ──
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generar_secreto_aleatorio_min_32_caracteres
JWT_EXPIRES_IN=86400

# ── Mail (SMTP) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_FROM="TuSuper <tu_correo@gmail.com>"

# ── Google OAuth ──
GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── Frontend (CORS whitelist, separado por comas) ──
FRONTEND_URL=http://localhost:4200

# ── Cloudinary (subida de imagenes, opcional) ──
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Seed de produccion ──
SEED_SECRET=secreto_largo_para_proteger_el_seed
ADMIN_EMAIL=admin@tusuper.com
ADMIN_PASSWORD=admin_password_inicial
